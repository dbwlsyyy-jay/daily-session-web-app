# 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요. (.env 는 절대 커밋하지 마세요)

# 서버 포트
PORT=4000

# RDS MySQL 접속 정보 (EC2 경유로만 접속)
DB_HOST=onboarding-test-3-db.cvcwq2206wfg.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=여기에_RDS_비밀번호   # 실제 값은 .env 에만, 커밋 금지
DB_NAME=appdb

# JWT 서명용 시크릿 (아무도 모르는 긴 랜덤 문자열)
JWT_SECRET=여기에_긴_랜덤_문자열

# 프론트 도메인 (CORS 허용용, 배포 후 Vercel URL)
CORS_ORIGIN=http://localhost:5173
